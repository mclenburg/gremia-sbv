{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist-electron",
    "rootDir": ".",
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "electron/**/*.ts",
    "services/**/*.ts",
    "database/**/*.ts"
  ]
}
