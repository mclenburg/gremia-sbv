    "test:bem-migration-051b": "vitest run tests/bemMigration051b.test.ts",
    "test:bem-ui-052": "vitest run tests/bemUi052.test.ts",
    "test:bem-ui-052a": "vitest run tests/bemUi052.test.ts",
    "test:migration-hardening-054": "vitest run tests/migrationHardening054.test.ts tests/databaseDiagnostics054.test.ts",
    "test:module-boundaries-a11y-055": "vitest run tests/moduleBoundariesA11y055.test.ts tests/liveRegionCoverage055.test.ts",
