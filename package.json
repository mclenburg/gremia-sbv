{
  "name": "gremia-sbv",
  "version": "0.9.2",
  "private": true,
  "description": "Offline-first Desktop-App für die vertrauliche Fallarbeit der Schwerbehindertenvertretung.",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k --success first \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && node scripts/write-electron-cjs-package.cjs && electron .",
    "build": "npm run test && tsc -p tsconfig.json && vite build && tsc -p tsconfig.electron.json && node scripts/write-electron-cjs-package.cjs",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:init": "tsx scripts/init-db.ts",
    "db:migrate": "tsx scripts/migrate-db.ts",
    "package": "electron-builder --dir",
    "dist": "electron-builder",
    "dev:electron:build": "tsc -p tsconfig.electron.json && node scripts/write-electron-cjs-package.cjs",
    "deps:linux": "bash scripts/install-linux-deps.sh",
    "native:rebuild": "npm run native:rebuild:electron",
    "native:rebuild:node": "npm rebuild better-sqlite3-multiple-ciphers --build-from-source",
    "native:rebuild:electron": "electron-rebuild -f -w better-sqlite3-multiple-ciphers",
    "native:clean": "node scripts/clean-native-build.cjs",
    "native:diagnose": "node scripts/diagnose-native-sqlcipher.cjs",
    "start:prod": "npm run build && electron .",
    "build:linux": "node scripts/build-platform.cjs linux",
    "launcher:linux": "bash scripts/create-linux-launcher.sh",
    "build:win": "node scripts/build-platform.cjs win",
    "build:windows": "npm run build:win",
    "build:all": "node scripts/build-current-platform.cjs",
    "debug:paths": "node -e \"console.log({cwd:process.cwd(),home:process.env.HOME,GREMIA_SBV_DATA_DIR:process.env.GREMIA_SBV_DATA_DIR})\"",
    "test:retention": "vitest run tests/retentionPolicy.test.ts",
    "release:check": "npm run rc:check && npm run test:coverage && npm run build",
    "test:privacy": "vitest run tests/contactPrivacyService.test.ts tests/reportPrivacyPolicy.test.ts tests/documentStoragePolicy.test.ts",
    "test:migrations": "vitest run tests/migrationService.test.ts",
    "test:backup": "vitest run tests/backupPolicy.test.ts",
    "test:prevention": "vitest run tests/preventionWorkflowPolicy.test.ts",
    "test:text-commands": "vitest run tests/textCommandPolicy.test.ts",
    "test:inline-overlays": "vitest run tests/textCommandPolicy.test.ts tests/openTaskDashboardPolicy.test.ts",
    "test:knowledge": "vitest run tests/knowledgePolicy.test.ts tests/knowledgeService.test.ts tests/knowledgeMigrationCompatibility.test.ts",
    "version:generate": "node scripts/generate-app-version.cjs",
    "predev": "npm run version:generate",
    "prebuild": "npm run version:generate && npm run source:cleanup && npm run build:readiness",
    "pretest": "npm run version:generate && npm run source:cleanup",
    "test:version": "vitest run tests/appVersion.test.ts",
    "test:templates": "vitest run tests/templatePolicy.test.ts",
    "test:contextual-templates": "vitest run tests/templateContextPolicy.test.ts",
    "test:case-modals": "vitest run tests/caseModalWorkflowPolicy.test.ts",
    "test:export-guard": "vitest run tests/exportGuardPolicy.test.ts",
    "test:case-workbench": "vitest run tests/caseWorkbenchWorkflowPolicy.test.ts",
    "postinstall": "electron-builder install-app-deps",
    "test:template-management": "vitest run tests/templateManagementEditDelete.test.ts",
    "test:inline-command-behavior": "vitest run tests/inlineCommandBehavior0456.test.ts",
    "test:templates-behavior": "vitest run tests/templatesBehavior0457.test.ts",
    "test:inline-command-behavior-fix": "vitest run tests/inlineCommandBehavior0456.test.ts",
    "test:bem-migration-051b": "vitest run tests/bemMigration051b.test.ts",
    "test:termination-hardening-072": "vitest run tests/terminationHardening072.test.ts tests/terminationTemplates072.test.ts",
    "test:ipc-validation-084f": "vitest run tests/ipcValidation084f.test.ts",
    "source:cleanup": "node scripts/cleanup-obsolete-files.cjs",
    "source:cleanup:dry-run": "node scripts/cleanup-obsolete-files.cjs --dry-run",
    "native:install-app-deps": "electron-builder install-app-deps",
    "build:readiness": "node scripts/check-build-readiness.cjs",
    "build:readiness:strict": "node scripts/check-build-readiness.cjs --strict",
    "source:cleanup:verbose": "node scripts/cleanup-obsolete-files.cjs --verbose",
    "rc:check": "npm run version:generate && npm run source:cleanup && npm run build:readiness:strict && npm run docs:diagrams:check && node scripts/check-release-candidate-readiness.cjs",
    "dev:renderer:e2e": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "test:e2e": "node scripts/run-e2e.cjs",
    "test:e2e:headed": "node scripts/run-e2e.cjs --headed",
    "test:e2e:debug": "node scripts/run-e2e.cjs --debug",
    "test:e2e:install": "node scripts/install-e2e-browsers.cjs",
    "test:e2e:docker": "docker build -f Dockerfile.e2e -t gremia-sbv-e2e . && docker run --rm gremia-sbv-e2e",
    "release:check:e2e": "npm run release:check && npm run test:e2e",
    "test:e2e:setup": "npm install --no-save @playwright/test@1.59.1 @axe-core/playwright@4.10.2 && npm run test:e2e:install",
    "build:mac": "node scripts/build-platform.cjs mac",
    "build:current": "node scripts/build-current-platform.cjs",
    "build:platforms:check": "node scripts/check-build-platforms.cjs",
    "test:coverage": "vitest run --coverage",
    "test:rc-fix-case-prevention-css-090rc1d": "vitest run tests/rcFixCasePreventionCss090rc1d.test.ts",
    "test:rc-fix-case-prevention-css-090rc1e": "vitest run tests/rcFixCasePreventionCss090rc1e.test.ts",
    "test:e2e:inline-commands": "node scripts/run-e2e.cjs e2e/inline-commands.spec.ts",
    "test:rc-windows-portable-artifact-090rc1o": "vitest run tests/rcWindowsPortableArtifact090rc1o.test.ts",
    "test:rc-final-test-sync-090rc1p": "vitest run tests/rcFinalTestSync090rc1p.test.ts",
    "test:protected-persons-091": "vitest run tests/protectedPersons091.test.ts",
    "test:person-import-091": "vitest run tests/personImport091.test.ts",
    "test:person-expiry-ical-091": "vitest run tests/personExpiryIcal091.test.ts",
    "test:rc-091-docs": "vitest run tests/rc091DocsAndArchitecture.test.ts",
    "test:person-import-wizard-091": "vitest run tests/personImportWizard091.test.ts",
    "cleanup:obsolete-release-notes": "node scripts/cleanup-obsolete-release-notes-091.cjs",
    "test:docs-current-091": "vitest run tests/rc091MarkdownDocsCurrent.test.ts",
    "test:rc-091-step-g-sync": "vitest run tests/rc091StepGReleaseSync.test.ts",
    "test:quality-ratio": "vitest run tests/rc091TestQualityRatio.test.ts",
    "docs:diagrams:check": "node scripts/check-diagram-assets.cjs",
    "css:usage:report": "node scripts/report-css-usage.cjs",
    "version:sync-lock": "node scripts/sync-package-lock-version.cjs",
    "test:e2e:visual": "node scripts/run-e2e.cjs e2e/visual-contract.spec.ts",
    "release:check:visual": "npm run build:readiness:strict && npm run test:e2e:visual",
    "test:e2e:core-ui-flows": "node scripts/run-e2e.cjs e2e/core-ui-flows.spec.ts",
    "release:check:core-ui": "npm run build:readiness:strict && npm run test:e2e:core-ui-flows",
    "test:e2e:complete-tour": "node scripts/run-e2e.cjs e2e/app-complete-tour.spec.ts",
    "release:check:complete-tour": "npm run build:readiness:strict && npm run test:e2e:complete-tour",
    "dev:electron:demo": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && node scripts/write-electron-cjs-package.cjs && electron . --demo",
    "dev:demo": "concurrently -k --success first \"npm:dev:renderer\" \"npm:dev:electron:demo\"",
    "start:demo": "npm run build && electron . --demo",
    "security:audit": "npm audit --audit-level=high",
    "licenses:generate": "node scripts/generate-third-party-licenses.cjs",
    "licenses:check": "node scripts/check-third-party-licenses.cjs",
    "release:public-check": "npm run security:audit && npm run licenses:check && npm run release:check && npm run test:e2e:visual && npm run test:e2e:core-ui-flows && npm run test:e2e:complete-tour && npm run test:e2e:a11y",
    "test:e2e:a11y": "node scripts/run-e2e.cjs e2e/accessibility-axe.spec.ts",
    "release:check:a11y": "npm run build:readiness:strict && npm run test:e2e:a11y"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "argon2-browser": "^1.18.0",
    "better-sqlite3-multiple-ciphers": "^12.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "docx": "^9.7.0",
    "ical-generator": "^10.2.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yauzl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.2",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "de.gremia.sbv",
    "productName": "Gremia.SBV",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "assets/**",
      "database/**",
      "LICENSE",
      "NOTICE",
      "THIRD_PARTY_LICENSES.txt",
      "SECURITY.md",
      "CHANGELOG.md",
      "docs/**"
    ],
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/*.node"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "icon": "assets/icons/png"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "Gremia.SBV",
      "requestedExecutionLevel": "asInvoker",
      "icon": "assets/icons/icon.ico",
      "signAndEditExecutable": false
    },
    "icon": "assets/icons/icon.png",
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "database",
        "to": "database"
      }
    ]
  },
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20.19.0 <25",
    "npm": ">=10"
  }
}
